# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).
# Custody: testnet only, throwaway key only. HTTP + this key = anyone with the
# URL + token can move its funds.

export STABLE_NETWORK=testnet              # must equal "testnet" or boot fails
export STABLE_PRIVATE_KEY=0x...            # testnet, throwaway
export MCP_AUTH_TOKEN=change-me            # shared bearer secret
export PORT=3000                           # optional (default 3000)
export ALLOWED_HOSTS=localhost:3000        # comma-sep Host allowlist (your-host.fly.dev in deploy)
export ALLOWED_ORIGINS=                    # optional, comma-sep Origin allowlist for browsers
export SESSION_TTL_MS=1800000              # optional, idle session eviction (30 min)
export HOST=127.0.0.1                      # bind addr; deploy sets 0.0.0.0 behind HTTPS proxy
